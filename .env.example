# ===========================
# Django Environment Configuration
# ===========================
# Copy this file to .env and update with your values
# DO NOT commit .env to version control
#
# Quick setup: cp .env.example .env && make init

# ===========================
# Django Settings
# ===========================
DJANGO_ENVIRONMENT=local
DEBUG=True
SECRET_KEY= # Will be generated by make init

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================
# Database (PostgreSQL)
# ===========================
# Default is SQLite - uncomment below and update to use PostgreSQL
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=project_db
# DB_USER=project_user
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432

# ===========================
# Email Configuration
# ===========================
# For local development use console backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production use SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@localhost.com

# ===========================
# Security Settings
# ===========================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ===========================
# Logging
# ===========================
LOG_LEVEL=INFO

# ===========================
# CORS Configuration
# ===========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
CORS_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ===========================
# Docker/Container Settings
# ===========================
DOCKER_ENVIRONMENT=local

# ===========================
# Admin Superuser
# ===========================
# These are used by make init to create superuser automatically
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# ===========================
# Login Credentials (Legacy)
# ===========================
# LOGIN_USERNAME=s@gmail.com
# LOGIN_PASSWORD=1

# ===========================
# API Documentation
# ===========================
API_TITLE=Django Rapido MINI API
API_DESCRIPTION=A lightweight, production-ready Django REST API template
API_VERSION=1.0.0
PRODUCTION_URL=https://api.yourdomain.com

# ===========================
# Testing Configuration
# ===========================
TESTING=False
TEST_DATABASE_NAME=project_test_db

